# Nexus API Configuration
# Copy this file to apps/api/.env and fill in your values

# Required: JWT secret for authentication (use a long random string)
JWT_SECRET=

# Required for Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# Optional: Database path (defaults to nexus.db)
DATABASE_URL=nexus.db

# Optional: API port (defaults to 3000)
PORT=3000

# Optional: OpenRouter API key for AI features (zero data retention enforced)
OPENROUTER_API_KEY=

# Optional: Override default AI models (any OpenRouter-supported model)
# AI_MODEL_WRITING=anthropic/claude-sonnet-4
# AI_MODEL_FAST=anthropic/claude-haiku-4

# Optional: App URL for OpenRouter attribution
# APP_URL=https://nexus.app
